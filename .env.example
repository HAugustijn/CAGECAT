# CAGECAT v2 — standalone configuration template.
#
# Copy this file to `.env` and adjust as needed:
#
#     cp .env.example .env
#
# The real `.env` file is git-ignored and must never be committed. Put any
# secrets (passwords, API keys, SMTP credentials, ...) here rather than in
# docker-compose.yml or the source tree.

# Public HTTP port for the web interface, served through nginx.
HTTP_PORT=1340

# Host port for direct (localhost-only) access to the FastAPI app, bypassing
# nginx. Handy for debugging; not required for normal use.
WEB_PORT=8004

# NCBI requires a contact e-mail for remote cblaster (BLAST) searches. Set this
# to your own address; without it, remote searches fail to start. An NCBI API
# key (optional) raises your request rate limit.
CBLASTER_EMAIL=you@example.com
# CBLASTER_API_KEY=
